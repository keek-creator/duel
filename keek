-- SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer

-- =========================
-- 📍 WAYPOINTS
-- =========================
local rightWaypoints = {
    Vector3.new(-473.04, -6.99, 29.71),
    Vector3.new(-483.57, -5.10, 18.74),
    Vector3.new(-475.00, -6.99, 26.43),
    Vector3.new(-474.67, -6.94, 105.48),
}

local leftWaypoints = {
    Vector3.new(-472.49, -7.00, 90.62),
    Vector3.new(-484.62, -5.10, 100.37),
    Vector3.new(-475.08, -7.00, 93.29),
    Vector3.new(-474.22, -6.96, 16.18),
}

-- =========================
-- STATES
-- =========================
local patrolMode = "none"
local currentWaypoint = 1
local floating = false
local infJump = false
local batAimbot = false
local autoGrab = false

local waitingLeft = false
local waitingRight = false
local AUTO_DELAY = 0.7

-- =========================
-- 🔹 COUNTDOWN DETECT
-- =========================
local function getTimerLabel()
    local ok, label = pcall(function()
        return player.PlayerGui
            :FindFirstChild("DuelsMachineTopFrame")
            .DuelsMachineTopFrame.Timer.Label
    end)
    return ok and label or nil
end

local function isCountdown(text)
    local n = tonumber(text)
    return n and n >= 1 and n <= 5
end

-- =========================
-- 🔹 MOVEMENT SYSTEM
-- =========================
RunService.Heartbeat:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- FLOAT
    if floating then
        root.AssemblyLinearVelocity = Vector3.new(
            root.AssemblyLinearVelocity.X,
            2,
            root.AssemblyLinearVelocity.Z
        )
    end

    -- AUTO DUEL
    if patrolMode ~= "none" then
        local waypoints = (patrolMode == "right") and rightWaypoints or leftWaypoints
        local target = waypoints[currentWaypoint]
        if not target then return end

        local pos = root.Position
        local dist = (Vector3.new(target.X,0,target.Z) - Vector3.new(pos.X,0,pos.Z)).Magnitude

        if dist > 3 then
            local dir = (target - pos).Unit
            root.AssemblyLinearVelocity = Vector3.new(dir.X * 60, root.AssemblyLinearVelocity.Y, dir.Z * 60)
        else
            currentWaypoint += 1
            if currentWaypoint > #waypoints then
                patrolMode = "none"
                currentWaypoint = 1
            end
        end
    end
end)

-- =========================
-- 🔹 INFINITE JUMP
-- =========================
UserInputService.JumpRequest:Connect(function()
    if not infJump then return end
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")

    if root then
        local v = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(v.X, 0, v.Z) + Vector3.new(0, 50, 0)
    end
end)

-- =========================
-- 🔹 BAT AIMBOT
-- =========================
local function getNearest()
    local char = player.Character
    if not char then return end

    local myHRP = char:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    local nearest, dist = nil, math.huge

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")

            if hrp and hum and hum.Health > 0 then
                local d = (hrp.Position - myHRP.Position).Magnitude
                if d < dist then
                    dist = d
                    nearest = hrp
                end
            end
        end
    end
    return nearest
end

RunService.Heartbeat:Connect(function()
    if not batAimbot then return end

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local target = getNearest()
    if target then
        local dir = (target.Position - hrp.Position)
        local flat = Vector3.new(dir.X, 0, dir.Z)

        if flat.Magnitude > 1 then
            local move = flat.Unit
            hrp.AssemblyLinearVelocity = Vector3.new(
                move.X * 55,
                hrp.AssemblyLinearVelocity.Y,
                move.Z * 55
            )
        end
    end
end)

-- =========================
-- 🔹 AUTO GRAB
-- =========================
RunService.Heartbeat:Connect(function()
    if not autoGrab then return end

    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Tool") then
            local handle = v:FindFirstChild("Handle")
            if handle and (handle.Position - root.Position).Magnitude <= 35 then
                pcall(function()
                    hum:EquipTool(v)
                end)
            end
        end
    end
end)

