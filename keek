end

local function setVisual(btn, grad, stroke, state, onTxt, offTxt)
    btn.Text = state and onTxt or offTxt
    btn.TextColor3 = state and Color3.new(1,1,1) or Color3.fromRGB(200, 180, 255)
    grad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, state and Color3.fromRGB(65, 20, 100) or Color3.fromRGB(26, 11, 46)),
        ColorSequenceKeypoint.new(1, state and Color3.fromRGB(20, 50, 80) or Color3.fromRGB(5, 5, 20))
    }
    stroke.Color = state and Color3.fromRGB(50, 255, 150) or Color3.fromRGB(138, 43, 226)
end

