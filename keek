local function makeBtn(text, y, func)
    local b = Instance.new("TextButton", frame)
    b.Size = UDim2.new(0.85,0,0,32)
    b.Position = UDim2.new(0.075,0,0,y)
    b.BackgroundColor3 = Color3.fromRGB(45,45,45)
    b.Text = text
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 12
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(func)
    return b
end

local infBtn = makeBtn("Infinite Jump OFF", 10, function()
    infJump = not infJump
    infBtn.Text = infJump and "Infinite Jump ON" or "OFF"
end)

local aimBtn = makeBtn("Bat Aimbot OFF", 50, function()
    batAimbot = not batAimbot
    aimBtn.Text = batAimbot and "Bat Aimbot ON" or "OFF"
end)

local grabBtn = makeBtn("Auto Grab OFF", 90, function()
    autoGrab = not autoGrab
    grabBtn.Text = autoGrab and "Auto Grab ON" or "OFF"
end)

local floatBtn = makeBtn("Float OFF", 130, function()
    floating = not floating
    floatBtn.Text = floating and "Float ON" or "OFF"
end)

local rightBtn = makeBtn("AutoRight", 170, function()
    patrolMode = "right"
    currentWaypoint = 1
end)

local leftBtn = makeBtn("AutoLeft", 210, function()
    patrolMode = "left"
    currentWaypoint = 1
end)

-- =========================
-- ⏱️ COUNTDOWN AUTO START
-- =========================
task.spawn(function()
    local label = getTimerLabel()
    if not label then return end

    label:GetPropertyChangedSignal("Text"):Connect(function()
        if isCountdown(label.Text) and tonumber(label.Text) == 1 then
            if waitingLeft then
                task.wait(AUTO_DELAY)
                patrolMode = "left"
                waitingLeft = false
            end
            if waitingRight then
                task.wait(AUTO_DELAY)
                patrolMode = "right"
                waitingRight = false
            end
        end
    end)
end)
