local function rc(frame, radius)
	if not frame then return end
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius or CR)
	corner.Parent = frame
end

local function st(frame, thickness, color, transparency)
	if not frame then return end
	local stroke = Instance.new("UIStroke")
	stroke.Thickness = thickness or 1
	stroke.Color = color or C.white
	stroke.Transparency = transparency or 0
	stroke.Parent = frame
end

