local function isMyBase(plotName)
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return false end
    local plot = plots:FindFirstChild(plotName)
    if not plot then return false end
    local sign = plot:FindFirstChild("PlotSign")
    if sign then
        local yourBase = sign:FindFirstChild("YourBase")
        if yourBase and yourBase:IsA("BillboardGui") then return yourBase.Enabled end
    end
    return false
end

local function ScanGrabbables()
    local results = {}
    local plots = workspace:FindFirstChild("Plots")
    if plots then
        for _, plot in ipairs(plots:GetChildren()) do
            if plot:IsA("Model") and not isMyBase(plot.Name) then
                local podiums = plot:FindFirstChild("AnimalPodiums")
                if podiums then
                    for _, podium in ipairs(podiums:GetChildren()) do
                        if podium:IsA("Model") then
                            local base = podium:FindFirstChild("Base")
                            local spawn = base and base:FindFirstChild("Spawn")
                            local attach = spawn and spawn:FindFirstChild("PromptAttachment")
                            if attach then
                                for _, p in ipairs(attach:GetChildren()) do
                                    if p:IsA("ProximityPrompt") then
                                        table.insert(results, {type="prompt", prompt=p, part=base or podium})
                                    end
                                end
                            end
                        end
                    end
                end
                for _, item in ipairs(plot:GetChildren()) do
                    if item:IsA("Tool") then
                        local handle = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
                        if handle then table.insert(results, {type="tool", tool=item, part=handle}) end
                    end
                end
            end
        end
    end

    for _, folderName in ipairs({"Debris","Drops","Collectibles","DroppedItems"}) do
        local folder = workspace:FindFirstChild(folderName)
        if folder then
            for _, desc in ipairs(folder:GetDescendants()) do
                if desc:IsA("ProximityPrompt") then
                    table.insert(results, {type="prompt", prompt=desc, part=desc.Parent})
                elseif desc:IsA("Tool") then
                    local handle = desc:FindFirstChild("Handle") or desc:FindFirstChildWhichIsA("BasePart")
                    if handle then table.insert(results, {type="tool", tool=desc, part=handle}) end
                end
            end
        end
    end

    for _, item in ipairs(workspace:GetChildren()) do
        if item:IsA("Tool") then
            local handle = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
            if handle then table.insert(results, {type="tool", tool=item, part=handle}) end
        end
    end
    CachedGrabbables = results
end

local function StartScan()
    if AutoGrabScanThread then return end
    AutoGrabScanThread = task.spawn(function()
        while AutoGrabConfig.AutoGrabEnabled do
            pcall(ScanGrabbables)
            task.wait(0.01)
        end
    end)
end

local function TryGrab(item, humanoid)
    if item.type == "prompt" then
        pcall(function() fireproximityprompt(item.prompt) end)
        pcall(function()
            item.prompt:InputHoldBegin()
            task.delay(0, function() if item.prompt and item.prompt.Parent then item.prompt:InputHoldEnd() end end)
        end)
    elseif item.type == "tool" then
        pcall(function() humanoid:EquipTool(item.tool) end)
    end
end

local function RunGrabLoop()
    if AutoGrabConnection then AutoGrabConnection:Disconnect() end
    AutoGrabConnection = RunService.Heartbeat:Connect(function()
        if not AutoGrabConfig.AutoGrabEnabled then return end
        local char = Player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not root or not hum then return end

        local now = tick()
        if now - lastGrabTick < GRAB_COOLDOWN then return end

        local myPos = root.Position
        local bestDist, bestItem = AutoGrabConfig.AutoGrabRadius + 1, nil

        for _, item in ipairs(CachedGrabbables) do
            if item.part and item.part.Parent then
                local success, pos = pcall(function()
                    return item.part:IsA("BasePart") and item.part.Position or item.part:GetPivot().Position
                end)
                if success and pos then
                    local dist = (pos - myPos).Magnitude
                    if dist < bestDist and ((item.type == "prompt" and item.prompt and item.prompt.Parent and item.prompt.Enabled) or (item.type == "tool" and item.tool and item.tool.Parent)) then
                        bestDist = dist
                        bestItem = item
                    end
                end
            end
        end

        if bestItem then
            lastGrabTick = now
            TryGrab(bestItem, hum)
        end
    end)
end

local function StartSpamToggle()
    if SpamToggleThread then return end
    SpamToggleThread = task.spawn(function()
        while AutoGrabConfig.AutoGrabEnabled do
            RunGrabLoop()
            task.wait(0.015)
            if AutoGrabConnection then AutoGrabConnection:Disconnect() AutoGrabConnection = nil end
            task.wait(0.005)
        end
    end)
end

local function StopAll()
    AutoGrabConfig.AutoGrabEnabled = false
    if SpamToggleThread then task.cancel(SpamToggleThread) SpamToggleThread = nil end
    if AutoGrabConnection then AutoGrabConnection:Disconnect() AutoGrabConnection = nil end
    if AutoGrabScanThread then task.cancel(AutoGrabScanThread) AutoGrabScanThread = nil end
    CachedGrabbables = {}
end

function startAutoSteal()
    AutoGrabConfig.AutoGrabEnabled = true
    StartScan()
    StartSpamToggle()
end

function stopAutoSteal()
    StopAll()
end

