-- AUTO STEAL (INSTA GRAB) - Standalone Version
-- Works with any executor
-- =============================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Player = Players.LocalPlayer

local AutoGrabConfig = {
    AutoGrabEnabled = false,
    AutoGrabRadius  = 35,   -- You can change this
}

local AutoGrabConnection  = nil
local AutoGrabScanThread  = nil
local SpamToggleThread    = nil
local CachedGrabbables    = {}
local GRAB_COOLDOWN       = 0.01
local lastGrabTick        = 0

-- Check if it's your own base (so we don't steal from ourselves)
local function isMyBase(plotName)
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return false end
    local plot = plots:FindFirstChild(plotName)
    if not plot then return false end
    local sign = plot:FindFirstChild("PlotSign")
    if sign then
        local yourBase = sign:FindFirstChild("YourBase")
        if yourBase and yourBase:IsA("BillboardGui") then
            return yourBase.Enabled == true
        end
    end
    return false
end

-- Scan all grabbable items/prompts
local function ScanGrabbables()
    local results = {}

    -- Scan Plots (other players' bases)
    local plots = workspace:FindFirstChild("Plots")
    if plots then
        for _, plot in ipairs(plots:GetChildren()) do
            if plot:IsA("Model") and not isMyBase(plot.Name) then
                -- Animal Podiums
                local podiums = plot:FindFirstChild("AnimalPodiums")
                if podiums then
                    for _, podium in ipairs(podiums:GetChildren()) do
                        if podium:IsA("Model") then
                            local base   = podium:FindFirstChild("Base")
                            local spawn  = base and base:FindFirstChild("Spawn")
                            local attach = spawn and spawn:FindFirstChild("PromptAttachment")
                            if attach then
                                for _, p in ipairs(attach:GetChildren()) do
                                    if p:IsA("ProximityPrompt") then
                                        table.insert(results, { type="prompt", prompt=p, part=base or podium })
                                    end
                                end
                            end
                        end
                    end
                end

                -- Tools in plot
                for _, item in ipairs(plot:GetChildren()) do
                    if item:IsA("Tool") then
                        local handle = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
                        if handle then
                            table.insert(results, { type="tool", tool=item, part=handle })
                        end
                    end
                end
            end
        end
    end

    -- Scan global drop folders
    for _, folderName in ipairs({"Debris","Drops","Collectibles","DroppedItems"}) do
        local folder = workspace:FindFirstChild(folderName)
        if folder then
            for _, desc in ipairs(folder:GetDescendants()) do
                if desc:IsA("ProximityPrompt") then
                    table.insert(results, { type="prompt", prompt=desc, part=desc.Parent })
                elseif desc:IsA("Tool") then
                    local handle = desc:FindFirstChild("Handle") or desc:FindFirstChildWhichIsA("BasePart")
                    if handle then
                        table.insert(results, { type="tool", tool=desc, part=handle })
                    end
                end
            end
        end
    end

    -- Loose tools in workspace
    for _, item in ipairs(workspace:GetChildren()) do
        if item:IsA("Tool") then
            local handle = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
            if handle then
                table.insert(results, { type="tool", tool=item, part=handle })
            end
        end
    end

    CachedGrabbables = results
end

local function StartScan()
    if AutoGrabScanThread then return end
    AutoGrabScanThread = task.spawn(function()
        while AutoGrabConfig.AutoGrabEnabled do
            pcall(ScanGrabbables)
            task.wait(0.01)
        end
    end)
end

local function TryGrab(item, humanoid)
    if item.type == "prompt" then
        pcall(function()
            fireproximityprompt(item.prompt)
        end)
        pcall(function()
            item.prompt:InputHoldBegin()
            task.delay(0, function()
                if item.prompt and item.prompt.Parent then
                    item.prompt:InputHoldEnd()
                end
            end)
        end)
    elseif item.type == "tool" then
        pcall(function()
            humanoid:EquipTool(item.tool)
        end)
    end
end

local function RunGrabLoop()
    if AutoGrabConnection then AutoGrabConnection:Disconnect() end

    AutoGrabConnection = RunService.Heartbeat:Connect(function()
        if not AutoGrabConfig.AutoGrabEnabled then return end

        local character = Player.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if not rootPart or not humanoid then return end

        local now = tick()
        if now - lastGrabTick < GRAB_COOLDOWN then return end

        local myPos    = rootPart.Position
        local radius   = AutoGrabConfig.AutoGrabRadius
        local bestDist = radius + 1
        local bestItem = nil

        for _, item in ipairs(CachedGrabbables) do
            if item.part and item.part.Parent then
                local success, pos = pcall(function()
                    return item.part:IsA("BasePart") and item.part.Position or item.part:GetPivot().Position
                end)
                if success and pos then
                    local dist = (pos - myPos).Magnitude
                    if dist < bestDist then
                        if (item.type == "prompt" and item.prompt and item.prompt.Parent and item.prompt.Enabled) or
                           (item.type == "tool" and item.tool and item.tool.Parent) then
                            bestDist = dist
                            bestItem = item
                        end
                    end
                end
            end
        end

        if bestItem then
            lastGrabTick = now
            TryGrab(bestItem, humanoid)
        end
    end)
end

local function StartSpamToggle()
    if SpamToggleThread then return end
    SpamToggleThread = task.spawn(function()
        while AutoGrabConfig.AutoGrabEnabled do
            RunGrabLoop()
            task.wait(0.015)
            if AutoGrabConnection then
                AutoGrabConnection:Disconnect()
                AutoGrabConnection = nil
            end
            task.wait(0.005)
        end
    end)
end

local function StopAll()
    AutoGrabConfig.AutoGrabEnabled = false

    if SpamToggleThread then
        task.cancel(SpamToggleThread)
        SpamToggleThread = nil
    end
    if AutoGrabConnection then
        AutoGrabConnection:Disconnect()
        AutoGrabConnection = nil
    end
    if AutoGrabScanThread then
        task.cancel(AutoGrabScanThread)
        AutoGrabScanThread = nil
    end

    CachedGrabbables = {}
end

-- Steal Paths
local stealPathActive = false
local stealLastFlatVel = Vector3.zero
local STEAL_PATH_VELOCITY_SPEED  = 59.2
local STEAL_PATH_SECOND_SPEED    = 29.6
local STEAL_PATH_BASE_STOP       = 1.35
local STEAL_PATH_MIN_STOP        = 0.65
local STEAL_PATH_NEXT_POINT_BIAS = 0.45
local STEAL_PATH_SMOOTH_FACTOR   = 0.12

local stealPath_Right = {
    {pos = Vector3.new(-470.6, -5.9, 34.4)},
    {pos = Vector3.new(-484.2, -3.9, 21.4)},
    {pos = Vector3.new(-475.6, -5.8, 29.3)},
    {pos = Vector3.new(-474.24, -7.09, 93.00)},
    {pos = Vector3.new(-482.57, -5.13, 94.51)}
}
local stealPath_Left = {
    {pos = Vector3.new(-474.7, -5.9, 91.0)},
    {pos = Vector3.new(-483.4, -3.9, 97.3)},
    {pos = Vector3.new(-474.7, -5.9, 91.0)},
    {pos = Vector3.new(-472.31, -7.09, 26.70)},
    {pos = Vector3.new(-482.74, -5.13, 24.12)}
}

local function stealMoveToPoint(hrp, current, nextPoint, speed)
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not stealPathActive then
            conn:Disconnect()
            hrp.AssemblyLinearVelocity = Vector3.zero
            return
        end
        local pos = hrp.Position
        local target = Vector3.new(current.X, pos.Y, current.Z)
        local dir = target - pos
        local dist = dir.Magnitude
        local stopDist = math.clamp(STEAL_PATH_BASE_STOP - dist * 0.04, STEAL_PATH_MIN_STOP, STEAL_PATH_BASE_STOP)
        if dist <= stopDist then conn:Disconnect() hrp.AssemblyLinearVelocity = Vector3.zero return end
        local moveDir = dir.Unit
        if nextPoint then
            local nextDir = (Vector3.new(nextPoint.X, pos.Y, nextPoint.Z) - pos).Unit
            moveDir = (moveDir + nextDir * STEAL_PATH_NEXT_POINT_BIAS).Unit
        end
        if stealLastFlatVel.Magnitude > 0.1 then
            moveDir = (moveDir * (1 - STEAL_PATH_SMOOTH_FACTOR) + stealLastFlatVel.Unit * STEAL_PATH_SMOOTH_FACTOR).Unit
        end
        local vel = Vector3.new(moveDir.X * speed, hrp.AssemblyLinearVelocity.Y, moveDir.Z * speed)
        hrp.AssemblyLinearVelocity = vel
        stealLastFlatVel = Vector3.new(vel.X, 0, vel.Z)
    end)
    while stealPathActive and
        (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(current.X, 0, current.Z)).Magnitude > STEAL_PATH_BASE_STOP do
        RunService.Heartbeat:Wait()
    end
end

local function stealRunPath(path)
    local hrp = (Player.Character or Player.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart")
    for i, p in ipairs(path) do
        if not stealPathActive then return end
        if i > 2 then break end
        local speed = i > 2 and STEAL_PATH_SECOND_SPEED or STEAL_PATH_VELOCITY_SPEED
        local nextP = path[i + 1] and path[i + 1].pos
        stealMoveToPoint(hrp, p.pos, nextP, speed)
        if i == 2 then task.wait(0.2) else task.wait(0.01) end
    end
end

function startStealPath(path)
    stealPathActive = true
    task.spawn(function()
        stealRunPath(path)
        stealPathActive = false

        -- Disable both AutoRight and AutoLeft
        Enabled.AutoRight = false
        Enabled.AutoLeft = false
        if VisualSetters.AutoRight then VisualSetters.AutoRight(false, true) end
        if VisualSetters.AutoLeft then VisualSetters.AutoLeft(false, true) end
        if floatButtonReferences.AutoRight then floatButtonReferences.AutoRight(false) end
        if floatButtonReferences.AutoLeft then floatButtonReferences.AutoLeft(false) end
    end)
end
function stopStealPath()
    stealPathActive = false
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
end

