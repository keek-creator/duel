-- [[ PREMIUM HUD BUTTON FACTORY ]] --
local function SetHUDState(btn, label, on)
    btn.Text = label .. "\n" .. (on and "ENABLED" or "DISABLED")
    local targetColor = on and THEME.Primary or THEME.LightDark
    TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor}):Play()
    btn.TextColor3 = on and THEME.Text or THEME.OffText
end

local function MakePremiumHUDButton(name, label, onToggle)
    local btn = Instance.new("TextButton", HUDScreen)
    btn.Size = UDim2.new(0, 118, 0, 42)
    btn.Position = resolvePosition(name)
    btn.BackgroundColor3 = THEME.LightDark
    btn.BorderSizePixel = 0
    btn.Text = label .. "\nDISABLED"
    btn.TextColor3 = THEME.OffText
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.AutoButtonColor = false
    btn.ZIndex = 5
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
    AddPremiumStroke(btn)
    CreateGradient(btn, 90)

    allButtons[name] = btn

    local active = false

    -- Hover effect (paid feel)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = THEME.Dark}):Play()
    end)
    btn.MouseLeave:Connect(function()
        if active then
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = THEME.Primary}):Play()
        else
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = THEME.LightDark}):Play()
        end
    end)

    MakeDraggable(btn, function()
        active = not active
        onToggle(active)
        SetHUDState(btn, label, active)
    end)

    return btn
end

