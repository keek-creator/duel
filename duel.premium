-- [[ PREMIUM THEME ]] --
local THEME = {
    Primary = Color3.fromRGB(180, 20, 20),      -- Premium Cherry Red
    Accent = Color3.fromRGB(255, 80, 80),
    Dark = Color3.fromRGB(15, 15, 15),
    LightDark = Color3.fromRGB(35, 35, 35),
    Text = Color3.fromRGB(255, 255, 255),
    OffText = Color3.fromRGB(180, 180, 180)
}

local function CreateGradient(parent, rotation)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, THEME.Dark),
        ColorSequenceKeypoint.new(1, THEME.LightDark)
    }
    gradient.Rotation = rotation or 90
    gradient.Parent = parent
    return gradient
end

local function AddPremiumStroke(frame)
    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = THEME.Primary
    stroke.Thickness = 1.8
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Transparency = 0.1
    return stroke
end

