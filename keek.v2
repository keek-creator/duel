-- ==================== KEEK DUEL GUI (v2) ====================

local pd = Color3.fromRGB(35, 15, 65)
local pm = Color3.fromRGB(70, 35, 140)
local pl = Color3.fromRGB(110, 55, 200)
local pa = Color3.fromRGB(150, 75, 255)
local pb = Color3.fromRGB(190, 115, 255)
local pg = Color3.fromRGB(210, 150, 255)
local bgc = Color3.fromRGB(12, 8, 20)
local wh = Color3.fromRGB(255, 255, 255)

local function drag(obj)
    local d, i, s, p
    obj.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            d = true
            s = inp.Position
            p = obj.Position
            inp.Changed:Connect(function()
                if inp.UserInputState == Enum.UserInputState.End then d = false end
            end)
        end
    end)
    obj.InputChanged:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then i = inp end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if inp == i and d then
            local delta = inp.Position - s
            obj.Position = UDim2.new(p.X.Scale, p.X.Offset + delta.X, p.Y.Scale, p.Y.Offset + delta.Y)
        end
    end)
end

local function new(c, props)
    local o = Instance.new(c)
    for k, v in pairs(props) do 
        if k ~= "Parent" then o[k] = v end 
    end
    if props.Parent then o.Parent = props.Parent end
    return o
end

local function mkGrad(p)
    local g = Instance.new("UIGradient", p)
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, pd),
        ColorSequenceKeypoint.new(0.3, pm),
        ColorSequenceKeypoint.new(0.6, pa),
        ColorSequenceKeypoint.new(1, pb)
    })
    return g
end

-- KEEK GUI
local par = (gethui and gethui()) or CoreGui
local keekGui = new("ScreenGui", {Name = "KEEKDUEL", ResetOnSpawn = false, Parent = par})

local main = new("Frame", {
    Name = "main",
    Size = UDim2.new(0, 160, 0, 172),
    Position = UDim2.new(0.5, -180, 0.5, -86),
    BackgroundColor3 = bgc,
    Parent = keekGui
})
new("UICorner", {CornerRadius = UDim.new(0, 8), Parent = main})
local mGrad = mkGrad(main)
local mStroke = new("UIStroke", {Color = pg, Thickness = 1.5, Parent = main})
drag(main)

new("TextLabel", {
    Size = UDim2.new(1, 0, 0, 30),
    Text = "KEEK DUEL",
    TextColor3 = pb,
    Font = Enum.Font.GothamBlack,
    TextSize = 16,
    BackgroundTransparency = 1,
    Parent = main
})

-- Stats Bar
local sf = new("Frame", {
    Size = UDim2.new(0, 280, 0, 28),
    Position = UDim2.new(0.5, -140, 0, 5),
    BackgroundColor3 = bgc,
    Parent = keekGui
})
new("UICorner", {CornerRadius = UDim.new(0, 8), Parent = sf})
local sStroke = new("UIStroke", {Color = pg, Thickness = 1.5, Parent = sf})
local sGrad = mkGrad(sf)
drag(sf)

new("TextLabel", {Size = UDim2.new(0.33, 0, 1, 0), Text = "KEEK DUEL", TextColor3 = pb, Font = Enum.Font.GothamBlack, TextSize = 11, BackgroundTransparency = 1, Parent = sf})
local fpslbl = new("TextLabel", {Size = UDim2.new(0.33, 0, 1, 0), Position = UDim2.new(0.33, 0, 0, 0), Text = "FPS: --", TextColor3 = pb, Font = Enum.Font.Gotham, TextSize = 11, BackgroundTransparency = 1, Parent = sf})
local pinglbl = new("TextLabel", {Size = UDim2.new(0.33, 0, 1, 0), Position = UDim2.new(0.66, 0, 0, 0), Text = "PING: --ms", TextColor3 = pb, Font = Enum.Font.Gotham, TextSize = 11, BackgroundTransparency = 1, Parent = sf})

-- Runtime
local fc = 0
local lu = tick()

RunService.RenderStepped:Connect(function(dt)
    fc = fc + 1
    local ct = tick()
    if ct - lu >= 1 then
        fpslbl.Text = "FPS: " .. math.floor(fc / (ct - lu))
        fc = 0
        lu = ct
    end
    local p = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    pinglbl.Text = "PING: " .. math.floor(p) .. "ms"
    
    mGrad.Rotation = (mGrad.Rotation + 80 * dt) % 360
    sGrad.Rotation = (sGrad.Rotation + 80 * dt) % 360
end)

-- Close with RightControl
UserInputService.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Enum.KeyCode.RightControl then
        keekGui:Destroy()
    end
end)

