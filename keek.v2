-- ==================== KEEK DUEL GUI (Red Outline) ====================
local gui = Instance.new("ScreenGui")
gui.Name = "KEEKDUEL"
gui.ResetOnSpawn = false
gui.ZIndexBehavior = Enum.ZIndexBehavior.Global
gui.Parent = CoreGui

local BG0 = Color3.fromRGB(8, 12, 22)
local BG1 = Color3.fromRGB(12, 18, 32)
local BG2 = Color3.fromRGB(18, 25, 45)
local BG3 = Color3.fromRGB(25, 35, 60)
local RED = Color3.fromRGB(255, 40, 40)     -- Red outline
local RED2 = Color3.fromRGB(220, 20, 20)
local WHT = Color3.fromRGB(240, 245, 255)
local DIM = Color3.fromRGB(110, 130, 170)

local W = S(280, 175)
local H = S(540, 340)

local win = Instance.new("Frame")
win.Name = "Window"
win.Size = isMobile and UDim2.new(0,W,0,H) or UDim2.new(0,W,0,H)
win.Position = isMobile and UDim2.new(0.5,-W/2,0,10) or UDim2.new(1,-(W+14),0.5,-H/2)
win.BackgroundColor3 = BG0
win.BorderSizePixel = 0
win.Active = true
win.Draggable = true
win.ClipsDescendants = true
win.Parent = gui

Instance.new("UICorner", win).CornerRadius = UDim.new(0,16)
local stroke = Instance.new("UIStroke", win)
stroke.Color = RED          -- ← Red Outline
stroke.Thickness = 2.5

-- Title changed to KEEK DUEL
local titleLbl = Instance.new("TextLabel", win)
titleLbl.Size = UDim2.new(1,0,0,50)
titleLbl.Position = UDim2.new(0,0,0,10)
titleLbl.BackgroundTransparency = 1
titleLbl.Text = "KEEK DUEL"
titleLbl.Font = Enum.Font.GothamBlack
titleLbl.TextSize = S(24, 18)
titleLbl.TextColor3 = RED2
titleLbl.TextXAlignment = Enum.TextXAlignment.Center

