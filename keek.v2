-- ==================== FEATURE STATES ====================
local Enabled = {
    AntiRagdoll       = false,
    AutoSteal         = false,
    Galaxy            = false,
    Optimizer         = false,
    Unwalk            = false,
    NoClip            = false,
    Spinbot           = false,
    RagdollTP         = true,
    AutoCarryOnPickup = false,
    WaypointESP       = false,
    SpeedLabel        = true,
    InfiniteJump      = false,
    FloatEnabled      = false,
    CounterMedusa     = false,
    BatAimbot         = false,
}

